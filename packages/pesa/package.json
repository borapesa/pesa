{
  "name": "@borapesa/pesa",
  "version": "0.6.6",
  "description": "Core — types, factory, event store, plugin system, and BogusProvider",
  "license": "MIT",
  "author": "Bora Pesa contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/borapesa/pesa.git",
    "directory": "packages/pesa"
  },
  "homepage": "https://borapesa.dev",
  "bugs": {
    "url": "https://github.com/borapesa/pesa/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./plugins": {
      "import": "./dist/plugins/index.js",
      "types": "./dist/plugins/index.d.ts"
    },
    "./testing": {
      "import": "./dist/testing/index.js",
      "types": "./dist/testing/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "payments",
    "tanzania",
    "selcom",
    "azampay",
    "clickpesa",
    "dpo",
    "pesapal",
    "mobile-money"
  ],
  "packageManager": "pnpm@10.33.3",
  "dependencies": {
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@types/uuid": "^11.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "provenance": true
  }
}
