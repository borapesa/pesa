{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true
  },
  "include": ["../packages/pesa/src/**/*.ts", "../providers/clickpesa/src/**/*.ts"],
  "exclude": ["**/*.test.ts", "**/node_modules/**"]
}
