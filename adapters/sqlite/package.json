{
  "name": "@borapesa/sqlite",
  "version": "0.0.4",
  "description": "SQLite event store adapter for Bora Pesa",
  "license": "MIT",
  "author": "Bora Pesa contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/borapesa/pesa.git",
    "directory": "adapters/sqlite"
  },
  "homepage": "https://borapesa.dev",
  "bugs": {
    "url": "https://github.com/borapesa/pesa/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "borapesa",
    "sqlite",
    "adapter",
    "events"
  ],
  "packageManager": "pnpm@10.33.3",
  "dependencies": {
    "@borapesa/pesa": "workspace:*",
    "better-sqlite3": "^12.11.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.0.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "provenance": true
  }
}
